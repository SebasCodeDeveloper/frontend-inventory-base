{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Angular Debug",
      "type": "chrome",
      "request": "launch",
      "url": "http://localhost:4200",
      // Fíjate aquí, añadimos la carpeta hija:
      "webRoot": "${workspaceFolder}", 
      "sourceMaps": true,
      "skipFiles": [
        "**/node_modules/**",
        "<node_internals>/**",
        "**/bootstrap.bundle.min.js",
        "**/scripts.js"
      ],
      "pathMapping": {
        "/": "${workspaceFolder}"
      }
    }
  ]
}